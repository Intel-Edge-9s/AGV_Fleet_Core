   <property name="styleSheet">
    <string notr="true">/* ============================================================
   1. 전역 스타일 및 배경 설정
   ============================================================ */
QWidget {
    background-color: #1b1e23;
    color: #d1d5db;
    font-family: &quot;Segoe UI&quot;, &quot;Malgun Gothic&quot;, &quot;Consolas&quot;, sans-serif;
    font-size: 13px;
}

/* ============================================================
   2. 컨테이너 (GroupBox &amp; QFrame 카드 디자인)
   ============================================================ */
QGroupBox {
    background-color: #242930;
    border: 1px solid #323842;
    border-radius: 12px;
    margin-top: 25px;
    font-weight: 800;
    letter-spacing: 1px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 15px;
    padding: 0 12px;
    color: #00f2ff;
    background-color: transparent;
}

QFrame {
    background-color: #2c313a;
    border: 1px solid #3e4451;
    border-radius: 8px;
}

QFrame:hover {
    border: 1px solid #26c6da;
    background-color: #353b45;
}

/* ============================================================
   3. 로봇 선택 타겟 셀렉터 (Target Selector)
   ============================================================ */
QRadioButton {
    background-color: #313742;
    color: #90a4ae;
    border: 1px solid #3e4551;
    border-radius: 6px;
    padding: 6px 12px;
    font-weight: bold;
    min-width: 80px;
}

QRadioButton::indicator {
    width: 0px; 
}

QRadioButton:hover {
    border: 1px solid #00f2ff;
    color: white;
}

QRadioButton:checked {
    background-color: #1e2e3a;
    border: 2px solid #00f2ff;
    color: #00f2ff;
}

/* ============================================================
   4. 일반 및 제어 버튼 디자인
   ============================================================ */
QPushButton {
    background-color: #313742;
    border: 1px solid #3e4551;
    border-radius: 6px;
    padding: 10px;
    font-weight: 600;
    color: #eceff1;
}

QPushButton:hover {
    background-color: #3a4250;
    border: 1px solid #00f2ff;
    color: #ffffff;
}

QPushButton:pressed {
    background-color: #00f2ff;
    color: #1b1e23;
}

QPushButton[objectName^=&quot;pPB&quot;] {
    background-color: #2c323d;
    font-size: 15px;
    border-radius: 8px;
}

#pPBStop {
    background-color: #3d2b2e;
    border: 2px solid #ff4d4d;
    color: #ff4d4d;
    font-weight: 900;
}

#pPBStop:hover {
    background-color: #ff4d4d;
    color: white;
}

/* ============================================================
   5. 물류 핵심 작업 및 자율주행 제어 버튼
   ============================================================ */
/* 적재 LOAD */
QPushButton[objectName$=&quot;Load&quot;] {
    border: 1px solid #00c853;
    color: #00c853;
    background-color: #1e2e26;
    font-size: 14px;
}

QPushButton[objectName$=&quot;Load&quot;]:hover {
    background-color: #00c853;
    color: #1b1e23;
}

/* 하역 UNLOAD */
QPushButton[objectName$=&quot;Unload&quot;] {
    border: 1px solid #ffab00;
    color: #ffab00;
    background-color: #2e281e;
    font-size: 14px;
}

QPushButton[objectName$=&quot;Unload&quot;]:hover {
    background-color: #ffab00;
    color: #1b1e23;
}

/* 자율주행 STOP 버튼 (강렬한 레드 테마) */
#btnStopNavi {
    background-color: #3d2b2e; /* 어두운 레드 배경 */
    border: 2px solid #ff4d4d;
    color: #ff4d4d;
    font-size: 14px;
    font-weight: 800;
}

#btnStopNavi:hover {
    background-color: #ff4d4d;
    color: #ffffff;
}

#btnStopNavi:pressed {
    background-color: #b33636;
    color: #eceff1;
}

/* ============================================================
   6. 라벨 스타일 및 데이터 박스 통합 (Voltage/Value)
   ============================================================ */
QLabel {
    qproperty-alignment: 'AlignCenter'; 
    font-weight: bold;
    color: #90a4ae; 
    margin-bottom: 5px;
    background-color: transparent;
    border: none;
}

QLabel[objectName*=&quot;Voltage&quot;] {
    color: #00f2ff;
    font-family: &quot;Consolas&quot;, monospace;
}

QLabel[objectName*=&quot;Value&quot;] {
    color: #00f2ff;
    font-family: &quot;Consolas&quot;, monospace;
    font-size: 15px;
    font-weight: bold;
    background-color: #121417;
    border: 1px solid #323842;
    border-radius: 6px;
    padding: 5px;
    min-height: 25px;
}

/* ============================================================
   7. 기타 입력 위젯 및 프로그레스 바
   ============================================================ */
QCheckBox {
    font-weight: bold;
    color: #00f2ff;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    border: 1px solid #3e4551;
    background-color: #1b1e23;
}

QCheckBox::indicator:checked {
    background-color: #00f2ff;
}

QComboBox {
    background-color: #1b1e23;
    border: 1px solid #3e4551;
    border-radius: 4px;
    padding: 5px;
    color: #d1d5db;
}

QProgressBar {
    background-color: #121417;
    border: 1px solid #323842;
    border-radius: 6px;
    text-align: center;
    color: white;
    font-weight: bold;
}

QProgressBar::chunk {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
                        stop:0 #00c6ff, stop:1 #00f2ff);
    border-radius: 5px;
}</string>
   </property>
